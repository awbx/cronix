{
  "$comment": "Conformance vectors for cronix manifest parsing and normalization. Every implementation (TS @awbx/cronix-sdk, Go internal/manifest, future SDKs) must agree on every vector. For valid vectors, parseManifest(input) succeeds and canonicalize(applyDefaults(parsed)) === expected. For invalid vectors, parseManifest(input) fails; the implementation MAY surface a different error message but MUST surface at least one issue at the listed errorPaths (joined with '/'). Add new vectors only with an RFC update.",
  "version": 1,
  "vectors": [
    {
      "name": "minimal-job-single-schedule",
      "valid": true,
      "input": {
        "version": 1,
        "app": "billing-service",
        "jobs": [
          {
            "name": "reconcile-payments",
            "schedule": "*/15 * * * *",
            "request": { "url": "https://billing.internal/api/v1/scheduled/reconcile-payments" }
          }
        ]
      },
      "expected": "{\"version\":1,\"app\":\"billing-service\",\"jobs\":[{\"name\":\"reconcile-payments\",\"schedules\":[\"*/15 * * * *\"],\"timezone\":\"UTC\",\"request\":{\"method\":\"POST\",\"url\":\"https://billing.internal/api/v1/scheduled/reconcile-payments\",\"headers\":{},\"body\":\"\"},\"policy\":{\"concurrency\":\"Forbid\",\"concurrency_scope\":\"host\",\"timeout_seconds\":60,\"retries\":{\"max_attempts\":3,\"min_seconds\":1,\"max_seconds\":60}},\"auth\":{\"secret_refs\":[]}}]}"
    },
    {
      "name": "shortcut-daily",
      "valid": true,
      "input": {
        "version": 1,
        "app": "reports",
        "jobs": [
          {
            "name": "nightly-rollup",
            "schedule": "@daily",
            "timezone": "Europe/Paris",
            "request": { "url": "https://reports.example.com/cron/rollup", "method": "POST" }
          }
        ]
      },
      "expected": "{\"version\":1,\"app\":\"reports\",\"jobs\":[{\"name\":\"nightly-rollup\",\"schedules\":[\"@daily\"],\"timezone\":\"Europe/Paris\",\"request\":{\"method\":\"POST\",\"url\":\"https://reports.example.com/cron/rollup\",\"headers\":{},\"body\":\"\"},\"policy\":{\"concurrency\":\"Forbid\",\"concurrency_scope\":\"host\",\"timeout_seconds\":60,\"retries\":{\"max_attempts\":3,\"min_seconds\":1,\"max_seconds\":60}},\"auth\":{\"secret_refs\":[]}}]}"
    },
    {
      "name": "every-shortcut",
      "valid": true,
      "input": {
        "version": 1,
        "app": "ops",
        "jobs": [
          {
            "name": "ping",
            "schedule": "@every 5m",
            "request": { "url": "https://ops.example.com/cron/ping" }
          }
        ]
      },
      "expected": "{\"version\":1,\"app\":\"ops\",\"jobs\":[{\"name\":\"ping\",\"schedules\":[\"@every 5m\"],\"timezone\":\"UTC\",\"request\":{\"method\":\"POST\",\"url\":\"https://ops.example.com/cron/ping\",\"headers\":{},\"body\":\"\"},\"policy\":{\"concurrency\":\"Forbid\",\"concurrency_scope\":\"host\",\"timeout_seconds\":60,\"retries\":{\"max_attempts\":3,\"min_seconds\":1,\"max_seconds\":60}},\"auth\":{\"secret_refs\":[]}}]}"
    },
    {
      "name": "multiple-schedules-array",
      "valid": true,
      "input": {
        "version": 1,
        "app": "ops",
        "jobs": [
          {
            "name": "watchdog",
            "schedules": ["*/5 9-17 * * 1-5", "0 * * * 0,6"],
            "request": { "url": "https://ops.example.com/cron/watchdog" }
          }
        ]
      },
      "expected": "{\"version\":1,\"app\":\"ops\",\"jobs\":[{\"name\":\"watchdog\",\"schedules\":[\"*/5 9-17 * * 1-5\",\"0 * * * 0,6\"],\"timezone\":\"UTC\",\"request\":{\"method\":\"POST\",\"url\":\"https://ops.example.com/cron/watchdog\",\"headers\":{},\"body\":\"\"},\"policy\":{\"concurrency\":\"Forbid\",\"concurrency_scope\":\"host\",\"timeout_seconds\":60,\"retries\":{\"max_attempts\":3,\"min_seconds\":1,\"max_seconds\":60}},\"auth\":{\"secret_refs\":[]}}]}"
    },
    {
      "name": "fully-specified-policy-and-headers",
      "valid": true,
      "input": {
        "version": 1,
        "app": "billing-service",
        "jobs": [
          {
            "name": "settle-invoices",
            "schedule": "0 2 * * *",
            "timezone": "UTC",
            "request": {
              "method": "POST",
              "url": "https://billing.internal/api/v1/scheduled/settle-invoices",
              "headers": { "X-Tenant": "primary", "Accept": "application/json" },
              "body": "{}"
            },
            "policy": {
              "concurrency": "Replace",
              "concurrency_scope": "global",
              "timeout_seconds": 120,
              "retries": { "max_attempts": 5, "min_seconds": 2, "max_seconds": 30 }
            },
            "auth": { "secret_refs": ["BILLING_CRON_V2", "BILLING_CRON_V1"] }
          }
        ]
      },
      "expected": "{\"version\":1,\"app\":\"billing-service\",\"jobs\":[{\"name\":\"settle-invoices\",\"schedules\":[\"0 2 * * *\"],\"timezone\":\"UTC\",\"request\":{\"method\":\"POST\",\"url\":\"https://billing.internal/api/v1/scheduled/settle-invoices\",\"headers\":{\"Accept\":\"application/json\",\"X-Tenant\":\"primary\"},\"body\":\"{}\"},\"policy\":{\"concurrency\":\"Replace\",\"concurrency_scope\":\"global\",\"timeout_seconds\":120,\"retries\":{\"max_attempts\":5,\"min_seconds\":2,\"max_seconds\":30}},\"auth\":{\"secret_refs\":[\"BILLING_CRON_V2\",\"BILLING_CRON_V1\"]}}]}"
    },
    {
      "name": "jobs-sorted-by-name-deterministically",
      "valid": true,
      "input": {
        "version": 1,
        "app": "ops",
        "jobs": [
          { "name": "zeta", "schedule": "@hourly", "request": { "url": "https://ops.example.com/cron/zeta" } },
          { "name": "alpha", "schedule": "@hourly", "request": { "url": "https://ops.example.com/cron/alpha" } },
          { "name": "mike", "schedule": "@hourly", "request": { "url": "https://ops.example.com/cron/mike" } }
        ]
      },
      "expected": "{\"version\":1,\"app\":\"ops\",\"jobs\":[{\"name\":\"alpha\",\"schedules\":[\"@hourly\"],\"timezone\":\"UTC\",\"request\":{\"method\":\"POST\",\"url\":\"https://ops.example.com/cron/alpha\",\"headers\":{},\"body\":\"\"},\"policy\":{\"concurrency\":\"Forbid\",\"concurrency_scope\":\"host\",\"timeout_seconds\":60,\"retries\":{\"max_attempts\":3,\"min_seconds\":1,\"max_seconds\":60}},\"auth\":{\"secret_refs\":[]}},{\"name\":\"mike\",\"schedules\":[\"@hourly\"],\"timezone\":\"UTC\",\"request\":{\"method\":\"POST\",\"url\":\"https://ops.example.com/cron/mike\",\"headers\":{},\"body\":\"\"},\"policy\":{\"concurrency\":\"Forbid\",\"concurrency_scope\":\"host\",\"timeout_seconds\":60,\"retries\":{\"max_attempts\":3,\"min_seconds\":1,\"max_seconds\":60}},\"auth\":{\"secret_refs\":[]}},{\"name\":\"zeta\",\"schedules\":[\"@hourly\"],\"timezone\":\"UTC\",\"request\":{\"method\":\"POST\",\"url\":\"https://ops.example.com/cron/zeta\",\"headers\":{},\"body\":\"\"},\"policy\":{\"concurrency\":\"Forbid\",\"concurrency_scope\":\"host\",\"timeout_seconds\":60,\"retries\":{\"max_attempts\":3,\"min_seconds\":1,\"max_seconds\":60}},\"auth\":{\"secret_refs\":[]}}]}"
    },
    {
      "name": "headers-sorted-deterministically",
      "valid": true,
      "input": {
        "version": 1,
        "app": "ops",
        "jobs": [
          {
            "name": "ping",
            "schedule": "@hourly",
            "request": {
              "url": "https://ops.example.com/cron/ping",
              "headers": { "Z-Last": "z", "A-First": "a", "M-Mid": "m" }
            }
          }
        ]
      },
      "expected": "{\"version\":1,\"app\":\"ops\",\"jobs\":[{\"name\":\"ping\",\"schedules\":[\"@hourly\"],\"timezone\":\"UTC\",\"request\":{\"method\":\"POST\",\"url\":\"https://ops.example.com/cron/ping\",\"headers\":{\"A-First\":\"a\",\"M-Mid\":\"m\",\"Z-Last\":\"z\"},\"body\":\"\"},\"policy\":{\"concurrency\":\"Forbid\",\"concurrency_scope\":\"host\",\"timeout_seconds\":60,\"retries\":{\"max_attempts\":3,\"min_seconds\":1,\"max_seconds\":60}},\"auth\":{\"secret_refs\":[]}}]}"
    },
    {
      "name": "missing-version",
      "valid": false,
      "input": { "app": "x", "jobs": [] },
      "errorPaths": ["version"]
    },
    {
      "name": "wrong-version",
      "valid": false,
      "input": { "version": 2, "app": "x", "jobs": [{ "name": "a", "schedule": "@hourly", "request": { "url": "https://x.example.com" } }] },
      "errorPaths": ["version"]
    },
    {
      "name": "missing-app",
      "valid": false,
      "input": { "version": 1, "jobs": [] },
      "errorPaths": ["app"]
    },
    {
      "name": "invalid-app-id-uppercase",
      "valid": false,
      "input": { "version": 1, "app": "Billing", "jobs": [{ "name": "a", "schedule": "@hourly", "request": { "url": "https://x.example.com" } }] },
      "errorPaths": ["app"]
    },
    {
      "name": "empty-jobs",
      "valid": false,
      "input": { "version": 1, "app": "x", "jobs": [] },
      "errorPaths": ["jobs"]
    },
    {
      "name": "missing-job-name",
      "valid": false,
      "input": { "version": 1, "app": "x", "jobs": [{ "schedule": "@hourly", "request": { "url": "https://x.example.com" } }] },
      "errorPaths": ["jobs/0/name"]
    },
    {
      "name": "invalid-job-name-uppercase",
      "valid": false,
      "input": { "version": 1, "app": "x", "jobs": [{ "name": "MyJob", "schedule": "@hourly", "request": { "url": "https://x.example.com" } }] },
      "errorPaths": ["jobs/0/name"]
    },
    {
      "name": "invalid-job-name-starts-with-digit",
      "valid": false,
      "input": { "version": 1, "app": "x", "jobs": [{ "name": "1job", "schedule": "@hourly", "request": { "url": "https://x.example.com" } }] },
      "errorPaths": ["jobs/0/name"]
    },
    {
      "name": "invalid-job-name-too-long",
      "valid": false,
      "input": { "version": 1, "app": "x", "jobs": [{ "name": "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa", "schedule": "@hourly", "request": { "url": "https://x.example.com" } }] },
      "errorPaths": ["jobs/0/name"]
    },
    {
      "name": "duplicate-job-names",
      "valid": false,
      "input": {
        "version": 1,
        "app": "x",
        "jobs": [
          { "name": "a", "schedule": "@hourly", "request": { "url": "https://x.example.com" } },
          { "name": "a", "schedule": "@daily", "request": { "url": "https://x.example.com" } }
        ]
      },
      "errorPaths": ["jobs/1/name"]
    },
    {
      "name": "neither-schedule-nor-schedules",
      "valid": false,
      "input": { "version": 1, "app": "x", "jobs": [{ "name": "a", "request": { "url": "https://x.example.com" } }] },
      "errorPaths": ["jobs/0"]
    },
    {
      "name": "both-schedule-and-schedules",
      "valid": false,
      "input": { "version": 1, "app": "x", "jobs": [{ "name": "a", "schedule": "@hourly", "schedules": ["@daily"], "request": { "url": "https://x.example.com" } }] },
      "errorPaths": ["jobs/0"]
    },
    {
      "name": "schedule-malformed-cron",
      "valid": false,
      "input": { "version": 1, "app": "x", "jobs": [{ "name": "a", "schedule": "not a cron", "request": { "url": "https://x.example.com" } }] },
      "errorPaths": ["jobs/0/schedule"]
    },
    {
      "name": "schedule-too-many-fields",
      "valid": false,
      "input": { "version": 1, "app": "x", "jobs": [{ "name": "a", "schedule": "0 0 * * * *", "request": { "url": "https://x.example.com" } }] },
      "errorPaths": ["jobs/0/schedule"]
    },
    {
      "name": "every-too-fast",
      "valid": false,
      "input": { "version": 1, "app": "x", "jobs": [{ "name": "a", "schedule": "@every 30s", "request": { "url": "https://x.example.com" } }] },
      "errorPaths": ["jobs/0/schedule"]
    },
    {
      "name": "missing-request-url",
      "valid": false,
      "input": { "version": 1, "app": "x", "jobs": [{ "name": "a", "schedule": "@hourly", "request": {} }] },
      "errorPaths": ["jobs/0/request/url"]
    },
    {
      "name": "non-http-url",
      "valid": false,
      "input": { "version": 1, "app": "x", "jobs": [{ "name": "a", "schedule": "@hourly", "request": { "url": "ftp://x.example.com" } }] },
      "errorPaths": ["jobs/0/request/url"]
    },
    {
      "name": "invalid-method",
      "valid": false,
      "input": { "version": 1, "app": "x", "jobs": [{ "name": "a", "schedule": "@hourly", "request": { "url": "https://x.example.com", "method": "TRACE" } }] },
      "errorPaths": ["jobs/0/request/method"]
    },
    {
      "name": "timeout-zero",
      "valid": false,
      "input": { "version": 1, "app": "x", "jobs": [{ "name": "a", "schedule": "@hourly", "request": { "url": "https://x.example.com" }, "policy": { "timeout_seconds": 0 } }] },
      "errorPaths": ["jobs/0/policy/timeout_seconds"]
    },
    {
      "name": "timeout-over-ceiling",
      "valid": false,
      "input": { "version": 1, "app": "x", "jobs": [{ "name": "a", "schedule": "@hourly", "request": { "url": "https://x.example.com" }, "policy": { "timeout_seconds": 601 } }] },
      "errorPaths": ["jobs/0/policy/timeout_seconds"]
    },
    {
      "name": "retry-min-greater-than-max",
      "valid": false,
      "input": { "version": 1, "app": "x", "jobs": [{ "name": "a", "schedule": "@hourly", "request": { "url": "https://x.example.com" }, "policy": { "retries": { "min_seconds": 30, "max_seconds": 10 } } }] },
      "errorPaths": ["jobs/0/policy/retries"]
    },
    {
      "name": "invalid-concurrency",
      "valid": false,
      "input": { "version": 1, "app": "x", "jobs": [{ "name": "a", "schedule": "@hourly", "request": { "url": "https://x.example.com" }, "policy": { "concurrency": "Allow-with-fallback" } }] },
      "errorPaths": ["jobs/0/policy/concurrency"]
    }
  ]
}
