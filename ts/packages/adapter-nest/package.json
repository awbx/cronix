{
  "name": "@awbx/cronix-adapter-nest",
  "version": "0.7.4",
  "description": "NestJS adapter for @awbx/cronix-sdk. Thin wrapper around the Express adapter for the default Nest platform.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build"
  },
  "files": [
    "dist"
  ],
  "author": "Abdelhadi Sabani",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/awbx/cronix.git",
    "directory": "ts/packages/adapter-nest"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "cronix",
    "cron",
    "nest",
    "nestjs",
    "adapter"
  ],
  "dependencies": {
    "@awbx/cronix-sdk": "workspace:*",
    "@awbx/cronix-adapter-express": "workspace:*"
  }
}
