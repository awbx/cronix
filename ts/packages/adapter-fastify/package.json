{
  "name": "@awbx/cronix-adapter-fastify",
  "version": "0.10.3",
  "description": "Fastify adapter for @awbx/cronix-sdk. Lifts cron.handle into a Fastify route handler with a raw-body content-type parser for HMAC verification.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build"
  },
  "files": [
    "dist"
  ],
  "author": "Abdelhadi Sabani",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/awbx/cronix.git",
    "directory": "ts/packages/adapter-fastify"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "cronix",
    "cron",
    "fastify",
    "adapter"
  ],
  "dependencies": {
    "@awbx/cronix-sdk": "workspace:*"
  },
  "peerDependencies": {
    "fastify": ">=4"
  },
  "devDependencies": {
    "fastify": "^5.8.5"
  }
}
