{
  "name": "@awbx/cronix-sdk",
  "version": "0.7.2",
  "description": "App-side SDK for cronix: declare cron jobs in code, build the manifest, verify signed triggers. Framework-agnostic — works with anything that exposes a Web Request (Hono, Bun, Workers, Vercel) or via a sister adapter package for Express / Fastify / Koa / NestJS.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build"
  },
  "files": [
    "dist"
  ],
  "author": "Abdelhadi Sabani",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/awbx/cronix.git",
    "directory": "ts/packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "cron",
    "scheduler",
    "cronix",
    "typescript",
    "hmac",
    "manifest"
  ],
  "dependencies": {
    "cron-parser": "^5.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "express": "^4.22.1",
    "fastify": "^5.8.5",
    "hono": "^4.12.16"
  }
}
