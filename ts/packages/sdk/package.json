{
  "name": "@cronix/sdk",
  "version": "0.0.0",
  "description": "App-side SDK for cronix: register cron jobs in code, serve manifests, verify signed triggers.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./express": {
      "import": {
        "types": "./dist/express/index.d.ts",
        "default": "./dist/express/index.js"
      },
      "require": {
        "types": "./dist/express/index.d.cts",
        "default": "./dist/express/index.cjs"
      }
    },
    "./fastify": {
      "import": {
        "types": "./dist/fastify/index.d.ts",
        "default": "./dist/fastify/index.js"
      },
      "require": {
        "types": "./dist/fastify/index.d.cts",
        "default": "./dist/fastify/index.cjs"
      }
    },
    "./hono": {
      "import": {
        "types": "./dist/hono/index.d.ts",
        "default": "./dist/hono/index.js"
      },
      "require": {
        "types": "./dist/hono/index.d.cts",
        "default": "./dist/hono/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build"
  },
  "files": [
    "dist"
  ],
  "author": "Abdelhadi Sabani",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/awbx/cronix.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "cron",
    "scheduler",
    "cronix",
    "typescript",
    "hmac",
    "manifest"
  ],
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "hono": {
      "optional": true
    }
  },
  "peerDependencies": {
    "express": ">=4",
    "fastify": ">=4",
    "hono": ">=4"
  },
  "dependencies": {
    "cron-parser": "^5.5.0",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  }
}
