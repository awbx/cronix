{
  "name": "@cronix-example/hono-app",
  "version": "0.7.0",
  "private": true,
  "description": "Wiring @awbx/cronix-sdk into Hono — runs unchanged on Node, Bun, and Cloudflare Workers.",
  "type": "module",
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "start": "tsx src/index.ts",
    "bun": "bun run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@awbx/cronix-sdk": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "hono": "^4.10.4"
  },
  "devDependencies": {
    "tsx": "^4.20.6"
  }
}
